# Database
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/smartscope?retryWrites=true&w=majority

# Email Service (SendGrid)
SENDGRID_API_KEY=your_sendgrid_api_key

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:3000

# Analytics
NEXT_PUBLIC_GTAG_ID=your_google_analytics_id

# Admin Authentication
ADMIN_SECRET_KEY=your_secret_key_for_admin

# File Upload (Optional - for Cloudinary or similar)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
